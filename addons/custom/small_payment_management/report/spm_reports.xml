<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cross-package report pack (report §11.2). Skeleton: budget utilization.
         Remaining reports (#1, #3-#12) to be added as packages are built. -->

    <record id="action_report_budget_utilization" model="ir.actions.report">
        <field name="name">Budget Utilization</field>
        <field name="model">spm.budget</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">small_payment_management.report_budget_utilization</field>
        <field name="report_file">small_payment_management.report_budget_utilization</field>
        <field name="binding_model_id" ref="model_spm_budget"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_budget_utilization">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Budget Utilization</h2>
                        <p>Budget: <span t-field="doc.name"/></p>
                        <!-- TODO: Planned / Reserved / Utilized / Available / % by
                             company -> branch -> type -> category with RAG bands -->
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
