<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Multi-company rule on the branch master -->
    <record id="rule_spm_branch_company" model="ir.rule">
        <field name="name">SPM Branch: multi-company</field>
        <field name="model_id" ref="model_spm_branch"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Branch restriction on petty cash vouchers for non-managers -->
    <record id="rule_spm_voucher_branch" model="ir.rule">
        <field name="name">SPM Voucher: allowed branches</field>
        <field name="model_id" ref="model_spm_petty_cash_voucher"/>
        <field name="groups" eval="[(4, ref('group_spm_employee'))]"/>
        <field name="domain_force">
            ['|', ('branch_id', '=', False),
             ('branch_id', 'in', user.spm_branch_ids.ids)]
        </field>
    </record>

</odoo>
